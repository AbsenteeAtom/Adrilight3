<UserControl x:Class="adrilight.View.SettingsWindowComponents.Diagnostics"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="13"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{StaticResource MaterialDesignFont}"
             d:DesignHeight="900" d:DesignWidth="900">

    <!-- Root grid: outer DataContext is SettingsViewModel (inherited from window).
         The inner Grid re-routes DataContext to Diagnostics (DiagnosticsViewModel) for
         the log list and controls. The Night Light card stays at the outer level. -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Night Light status — binds to SettingsViewModel.NightLightConfidenceDisplay
             (outer DataContext) -->
        <materialDesign:Card Grid.Row="0" Margin="4 4 4 0">
            <StackPanel Margin="24 16 24 16" Orientation="Horizontal">
                <materialDesign:PackIcon Kind="WeatherNight" Width="20" Height="20"
                                         VerticalAlignment="Center" Margin="0 0 10 0"
                                         Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock VerticalAlignment="Center"
                           Text="{Binding Diagnostics.NightLightConfidenceDisplay}"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </materialDesign:Card>

        <!-- Log viewer — inner DataContext = DiagnosticsViewModel -->
        <Grid Grid.Row="1" DataContext="{Binding Diagnostics}" Margin="4 4 4 4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter toolbar -->
            <materialDesign:Card Grid.Row="0" Margin="0 0 0 4">
                <DockPanel Margin="12 8 12 8">
                    <Button DockPanel.Dock="Right"
                            Content="Mark as read"
                            Command="{Binding AcknowledgeCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Height="30" Padding="12 0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Show:" VerticalAlignment="Center" Margin="0 0 8 0"
                                   Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                        <RadioButton Content="All" GroupName="DiagFilter" Margin="0 0 8 0"
                                     VerticalAlignment="Center"
                                     IsChecked="{Binding FilterAll, Mode=TwoWay}"/>
                        <RadioButton Content="Warnings+" GroupName="DiagFilter" Margin="0 0 8 0"
                                     VerticalAlignment="Center"
                                     IsChecked="{Binding FilterWarnPlus, Mode=TwoWay}"/>
                        <RadioButton Content="Errors+" GroupName="DiagFilter"
                                     VerticalAlignment="Center"
                                     IsChecked="{Binding FilterErrorPlus, Mode=TwoWay}"/>
                    </StackPanel>
                </DockPanel>
            </materialDesign:Card>

            <!-- Log entry list -->
            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredEntries}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     VirtualizingPanel.IsVirtualizing="True"
                     BorderThickness="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource MaterialDesignListBoxItem}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="8 4"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding TimestampDisplay}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding LevelDisplay}"
                                       FontFamily="Consolas" FontSize="11" FontWeight="SemiBold"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LevelDisplay}" Value="WARN">
                                                <Setter Property="Foreground" Value="#FFC107"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LevelDisplay}" Value="ERROR">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LevelDisplay}" Value="FATAL">
                                                <Setter Property="Foreground" Value="#F44336"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Grid.Column="2" Text="{Binding ShortLogger}"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Text="{Binding Message}"
                                       FontSize="11" VerticalAlignment="Center"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Message}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
