<UserControl x:Class="adrilight.View.SettingsWindowComponents.SoundToLightSetup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="13"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{StaticResource MaterialDesignFont}"
             d:DesignHeight="900" d:DesignWidth="900">
    <WrapPanel Margin="0 0 8 8">

        <materialDesign:Card Margin="4 4 4 4" Width="900">
            <StackPanel Margin="16 12 16 12">
                <TextBlock FontWeight="Bold">Sound to Light</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 8 0 0" TextAlignment="Justify">
                    Captures your system's audio output (WASAPI loopback — no microphone required) and drives the
                    LEDs in real time. Each LED is randomly assigned a frequency band from 20 Hz to 20 kHz.
                    Band colours follow the visible spectrum: bass frequencies glow red and orange, mids shift
                    through yellow and green, treble lights up cyan and blue, and the highest bands show violet.
                    A strong bass hit reshuffles all LED assignments for a dynamic, ever-changing pattern.
                    <LineBreak />
                    <LineBreak />
                    Switch to Sound to Light mode on the General Setup tab. The LEDs revert to Screen Capture when you switch back.
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Margin="4 4 4 4" Width="440">
            <StackPanel Margin="16 12 16 16">
                <TextBlock FontWeight="Bold">Sensitivity</TextBlock>
                <DockPanel Margin="0 8 0 0">
                    <TextBox DockPanel.Dock="Right"
                             MinWidth="50" Margin="8 0 0 8" VerticalAlignment="Bottom"
                             Text="{Binding Settings.SoundToLightSensitivity, UpdateSourceTrigger=PropertyChanged}" />
                    <Slider Minimum="1" Maximum="100"
                            Style="{StaticResource MaterialDesignDiscreteSlider}"
                            Value="{Binding Settings.SoundToLightSensitivity}" />
                </DockPanel>
                <TextBlock TextWrapping="Wrap" Margin="0 8 0 0" TextAlignment="Justify">
                    How strongly the audio signal drives LED brightness. Raise this if the LEDs look dim at your
                    typical listening volume; lower it if they saturate or look washed out. Default is 50.
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Margin="4 4 4 4" Width="440">
            <StackPanel Margin="16 12 16 16">
                <TextBlock FontWeight="Bold">Smoothing</TextBlock>
                <DockPanel Margin="0 8 0 0">
                    <TextBox DockPanel.Dock="Right"
                             MinWidth="50" Margin="8 0 0 8" VerticalAlignment="Bottom"
                             Text="{Binding Settings.SoundToLightSmoothing, UpdateSourceTrigger=PropertyChanged}" />
                    <Slider Minimum="1" Maximum="100"
                            Style="{StaticResource MaterialDesignDiscreteSlider}"
                            Value="{Binding Settings.SoundToLightSmoothing}" />
                </DockPanel>
                <TextBlock TextWrapping="Wrap" Margin="0 8 0 0" TextAlignment="Justify">
                    Controls how smoothly the LEDs transition between levels. Low values give a fast, raw response
                    that follows every beat precisely. High values produce a silky, gradual fade that is easier
                    on the eyes for sustained listening. Default is 50.
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Margin="4 4 4 4" Width="900">
            <StackPanel Margin="16 12 16 16">
                <TextBlock FontWeight="Bold">Colour Channel Gain</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 6 0 12" TextAlignment="Justify">
                    Adjust the relative intensity of each colour channel. Values above 1.0 boost a channel;
                    values below 1.0 attenuate it. Defaults are Red 0.60, Green 1.05, Blue 1.50 — tuned for
                    a cool, blue-shifted palette across most LED strips.
                </TextBlock>

                <!-- Red -->
                <TextBlock>Red</TextBlock>
                <DockPanel Margin="0 4 0 8">
                    <TextBox DockPanel.Dock="Right"
                             MinWidth="50" Margin="8 0 0 0" VerticalAlignment="Bottom"
                             Text="{Binding Settings.SoundToLightRedGain, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                    <Slider Minimum="0" Maximum="2"
                            TickPlacement="BottomRight" TickFrequency="0.25"
                            IsSnapToTickEnabled="False"
                            Value="{Binding Settings.SoundToLightRedGain}" />
                </DockPanel>

                <!-- Green -->
                <TextBlock>Green</TextBlock>
                <DockPanel Margin="0 4 0 8">
                    <TextBox DockPanel.Dock="Right"
                             MinWidth="50" Margin="8 0 0 0" VerticalAlignment="Bottom"
                             Text="{Binding Settings.SoundToLightGreenGain, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                    <Slider Minimum="0" Maximum="2"
                            TickPlacement="BottomRight" TickFrequency="0.25"
                            IsSnapToTickEnabled="False"
                            Value="{Binding Settings.SoundToLightGreenGain}" />
                </DockPanel>

                <!-- Blue -->
                <TextBlock>Blue</TextBlock>
                <DockPanel Margin="0 4 0 0">
                    <TextBox DockPanel.Dock="Right"
                             MinWidth="50" Margin="8 0 0 0" VerticalAlignment="Bottom"
                             Text="{Binding Settings.SoundToLightBlueGain, StringFormat=F2, UpdateSourceTrigger=PropertyChanged}" />
                    <Slider Minimum="0" Maximum="2"
                            TickPlacement="BottomRight" TickFrequency="0.25"
                            IsSnapToTickEnabled="False"
                            Value="{Binding Settings.SoundToLightBlueGain}" />
                </DockPanel>

            </StackPanel>
        </materialDesign:Card>

    </WrapPanel>
</UserControl>
