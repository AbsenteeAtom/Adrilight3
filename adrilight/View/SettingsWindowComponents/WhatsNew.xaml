<UserControl x:Class="adrilight.View.SettingsWindowComponents.WhatsNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="13"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{StaticResource MaterialDesignFont}"
             d:DesignHeight="900" d:DesignWidth="900">
    <Grid Width="900">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <materialDesign:Card Margin="4 4 4 4" Grid.Row="0">
            <StackPanel Margin="38 28 38 28">
                <TextBlock FontSize="24" FontWeight="Bold" Margin="0 0 0 16">adrilight</TextBlock>
                <TextBlock FontSize="16" Margin="0 0 0 8">
                    Version 2.1.0 — Perry Edition
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 8">
                    Based on adrilight 2.0.9 by fabsenet. Forked and upgraded with the following improvements:
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <materialDesign:Card Margin="4 0 4 4" Grid.Row="1">
            <StackPanel Margin="38 28 38 28">
                <TextBlock FontWeight="Bold" Margin="0 0 0 12">What's new in 2.1.0</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    ● Migrated from .NET Framework 4.7.2 to .NET 8 — faster, lower CPU and GPU usage.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    ● TCP control server on port 5080 — Remote 7 can now send ON, OFF, TOGGLE, STATUS and EXIT commands directly.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    ● Dirty flag optimisation — serial data is only sent to the Arduino when screen colours have actually changed.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    ● Removed Squirrel auto-updater — eliminates antivirus false positives.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    ● Default frame rate reduced to 30fps — significantly lower GPU usage with no visible difference to LEDs.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    ● Updated all dependencies to current versions.
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>
