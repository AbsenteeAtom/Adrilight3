<UserControl x:Class="adrilight.View.SettingsWindowComponents.WhatsNew"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             TextElement.Foreground="{DynamicResource MaterialDesignBody}"
             TextElement.FontWeight="Regular"
             TextElement.FontSize="13"
             TextOptions.TextFormattingMode="Ideal"
             TextOptions.TextRenderingMode="Auto"
             Background="{DynamicResource MaterialDesignPaper}"
             FontFamily="{StaticResource MaterialDesignFont}"
             d:DesignHeight="900" d:DesignWidth="900">
    <Grid Width="900">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <materialDesign:Card Margin="4 4 4 4" Grid.Row="0">
            <StackPanel Margin="38 28 38 28">
                <TextBlock FontSize="24" FontWeight="Bold" Margin="0 0 0 8">adrilight</TextBlock>
                <TextBlock FontSize="16" Margin="0 0 0 12">Version 3.7.2 — AbsenteeAtom Edition</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 6">
                    Ambient LED lighting for Windows. Captures your screen in real time using the Desktop Duplication API,
                    calculates the average colour across zones around the edge of the screen, and drives a WS2812b LED
                    strip via an Arduino — creating an immersive backlight effect behind your monitor or TV.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource MaterialDesignBodyLight}" Margin="0 8 0 0">
                    Forked from adrilight 2.0.9 by fabsenet (MIT). Original Desktop Duplication sample by jasonpang.
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <!-- What's new -->
        <materialDesign:Card Margin="4 0 4 4" Grid.Row="1">
            <StackPanel Margin="38 28 38 28">
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 0 0 16">What's new in 3.7.2</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Spanning toggle bug fix</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Fixed: toggling Span two displays on or off could cause "GetNextFrame() failed" errors
                    on the next capture cycle. Root cause: creating or destroying a second DXGI
                    DuplicateOutput session on the same adapter invalidates the primary session. The fix
                    discards both the primary and secondary duplicator instances when spanning is toggled,
                    so both are rebuilt cleanly on the next frame.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 16 0 16">What's new in 3.7.1</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Dual-display spanning</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Enable Span two displays on the General tab to stitch two side-by-side monitors into one
                    wide ambient surface. Both displays are captured simultaneously, stitched pixel-perfectly
                    at 1/8 scale, and fed into the existing spot sampling pipeline as a single wide frame.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● A second monitor dropdown appears when spanning is enabled — select the right-hand display.
                    The setting takes effect immediately; no restart required.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Set SpotsX to the total number of LEDs across the combined top and bottom runs of both
                    monitors. Black bar detection and all colour corrections continue to work on the stitched frame
                    without any changes to the LED setup.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.7.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Multi-monitor support</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● A new Capture Display selector on the General tab lets you choose which monitor drives the
                    LEDs. Previously adrilight always captured the first DXGI output (adapter 0, output 0).
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Available displays are enumerated at startup and labelled with their resolution and whether
                    they are the primary display — for example "Display 1 — 1920×1080 (Primary)".
                    Only displays that are currently attached to the desktop are listed.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● The selection is persisted in settings. Changing it takes effect immediately without
                    restarting adrilight — the capture pipeline rebuilds against the new output on the next frame.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Single-monitor users see a single entry and no behaviour change — the feature is
                    invisible unless more than one display is available.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.6.5</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — Colour mapping redesign</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● The frequency-to-colour mapping is now piecewise. The lower eight octaves (20 Hz–10 kHz)
                    use a logarithmic curve from red through to cyan. The 10–14 kHz band maps to blue, and
                    14–20 kHz maps to violet. The two transition points are mathematically continuous so there
                    is no visible colour step at the boundaries.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● The visible wavelength range is extended from 400–700 nm to 380–700 nm. The deepest violet
                    (380 nm, appearing magenta-purple) is now reachable and is reserved for the very highest
                    frequency content.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Blue and violet are no longer at the rarely-reached end of a gradient — they are dedicated
                    to cymbal, hi-hat, and air content above 10 kHz, making them meaningful visual indicators.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — Band Spread</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● New Band Spread toggle on the Sound to Light settings tab. When on, each LED also responds
                    to energy in the two adjacent frequency bands on each side (at 50% and 15% respectively),
                    keeping more LEDs active during narrow-spectrum content such as pure tones. Off by default;
                    does not affect colour assignment, only brightness.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — Smooth reshuffle transitions</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Fixed: LED brightness used to snap to black on every bass-triggered reshuffle, then ramp
                    back up through the attack smoothing — producing a stepped, stuttering effect, especially
                    at startup. Brightness is now preserved across reshuffles; each LED fades smoothly into
                    its new band's level rather than restarting from zero.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.6.4</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — Auto BPM detection</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● New Auto detect toggle on the Sound to Light settings tab. When on, adrilight
                    analyses the spectral flux of the audio in real time using a windowed
                    autocorrelation algorithm to estimate the music's tempo, and uses that tempo to
                    control the LED reshuffle rate automatically.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● A confidence score and live status line ("Detected: 124 BPM — Good lock" /
                    "Weak signal" / "Detecting…") are shown below the slider so you can see exactly
                    what the algorithm is doing.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● When Auto detect is on, the slider is relabelled "Fallback BPM" and applies
                    whenever detection confidence is too low (e.g. quiet passages, arrhythmic music,
                    or the first few seconds of playback). When Auto detect is off, the slider
                    behaves exactly as before and is labelled "Max BPM".
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● A hard ceiling of 240 BPM is always enforced regardless of detected tempo,
                    preventing runaway on sudden noise transients. Default: Auto detect on,
                    Fallback BPM 120.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.6.3</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — Max BPM</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● New Max BPM slider on the Sound to Light settings tab. Controls how frequently LED
                    colour assignments can reshuffle on a strong bass hit. Range is 30–240 BPM in steps
                    of 5; the label updates live to show the current value. Default is 120 BPM (500 ms
                    between reshuffles). Previously the rate limit was hardcoded at 1000 ms.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.6.2</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Diagnostics</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● All settings changes now appear in the Diagnostics tab in real time — each entry
                    shows the setting name and its new value, making it easy to confirm that a change
                    was applied and persisted.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.6.1</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — Bug Fixes</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Fixed: beat-triggered LED reshuffles stopped firing after the first few seconds of
                    music. The previous beat detector compared the raw bass level against a smoothed
                    running average; the smoother caught up within ~300 ms so the threshold was always
                    above the signal. Replaced with a sensitivity-scaled fixed floor threshold — reshuffles
                    now fire reliably on every strong bass hit, rate-limited to once per second.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Fixed: surround and 7.1 audio devices (e.g. 8-channel WASAPI output) did not work
                    correctly. Stereo content from browsers and media players only populates the front-left
                    and front-right channels; mixing all reported channels diluted the signal by up to 4×,
                    making beat detection fail silently. The mono mix is now capped at front-L + front-R
                    regardless of how many channels the device reports.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Beat events are logged and visible in the Diagnostics tab — useful for confirming
                    the pipeline is responding to the music.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.6.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — improvements</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Colour Channel Gain sliders (Red, Green, Blue) added to the Sound to Light settings tab.
                    Each channel can be boosted up to 2× or attenuated to 0, letting you tune the colour
                    balance to your specific LED strip. Defaults are Red 0.60, Green 0.85, Blue 1.00.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Frequency range extended from 10 kHz to 20 kHz. LEDs assigned to the upper bands now
                    respond to high-frequency content (cymbals, hi-hats, air) with blue and violet colours.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Overall brightness increased to work naturally at typical listening volumes.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Tray icon — mode switching</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● The system tray context menu now lists all available lighting modes (Screen Capture,
                    Sound to Light, Gamer Mode). The active mode is indicated with a check mark. Clicking
                    a mode switches immediately — no need to open the Settings window.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sound to Light — initial release</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● New lighting mode: Sound to Light. Captures your system audio output (WASAPI loopback —
                    no microphone required) and drives the LEDs in real time using a physics-inspired model.
                    32 logarithmically-spaced frequency bands are mapped to the visible spectrum: bass glows
                    red and orange, mids shift through yellow and green, treble lights up cyan and blue.
                    Each LED is randomly assigned a frequency band; a strong bass hit reshuffles all
                    assignments for a dynamic, ever-changing pattern.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Sensitivity and Smoothing controls on the new Sound to Light settings tab. Sensitivity
                    scales how strongly audio levels drive LED brightness. Smoothing applies separate
                    attack and decay time constants — fast for sharp transients, slow for natural fades.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Lighting mode selector added to General Setup: choose Screen Capture or Sound to Light.
                    The active mode is shown in the TCP STATUS response and can be switched via MODE SCREEN
                    or MODE SOUND commands.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.5.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Architecture</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● ModeManager architecture introduced as the foundation for future lighting modes
                    (Sound to Light, Gamer Mode). The app continues to use Screen Capture mode in
                    this version; the infrastructure is in place for future modes to be added cleanly.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● TCP STATUS command now includes the active mode in its response:
                    {"status":"on","mode":"screen"}. New MODE commands: MODE SCREEN, MODE SOUND,
                    MODE GAMER, MODE STATUS — see the TCP API reference below.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Bug Fix</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Fixed: if the Windows screen saver activated while the session was already locked,
                    the LEDs would not turn back on after the session was unlocked. The session-lock
                    and screen-saver inhibitors previously shared a state variable; each is now tracked
                    independently so all inhibitors must clear before LEDs resume.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.4.2</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Bug Fixes</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Fixed: Night Light detection did not recognise the ON state on some Windows builds.
                    Different Windows versions write different byte values to the registry blob at the
                    detection position; both known ON values (0x15 and 0x12) are now handled.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Fixed: Night Light state changes (ON / OFF) were not appearing in the Diagnostics
                    tab log. The log level has been raised so transitions are always visible in the UI.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">UI</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Navigation sidebar label changed from the version string to "Menu".
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● White Balance page: info card icon updated, title and body text rewritten for
                    clarity, and the calibration tip corrected to explain colour ratio rather than
                    giving misleading absolute-value advice.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.4.1</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Bug Fixes</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Fixed: White Balance slider values could be saved above 100 after some sessions
                    due to a MaterialDesign discrete-slider layout quirk. All six white balance setters
                    now clamp to [1, 100]; a settings migration automatically repairs any previously
                    saved corrupt value on first launch.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Fixed: White Balance page mode icons (Forced On / Auto detect / Forced Off) were
                    misaligned vertically relative to their label text. Icons now correctly line up
                    with their corresponding labels.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.4.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Night Light Detection</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Night Light state is now read directly from the Windows registry — no ML model,
                    no probability scores, no uncertainty. The result is a definitive ON or OFF.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● If the registry key is not found (Night Light has never been configured on this
                    machine), the Diagnostics tab shows Unknown and logs a warning rather than
                    guessing Off.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Removed the Microsoft.ML dependency — the installer and publish folder are
                    significantly smaller as a result.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.3.1</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Bug Fix</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Status indicator now uses a solid circle with a black outline, ensuring it is clearly
                    visible against the orange toolbar background.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.3.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Diagnostics</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Status indicator in the toolbar — coloured circle turns amber on warnings and red on errors.
                    Tooltip shows the current state; click to jump directly to the Diagnostics tab.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● In-app log viewer on the Diagnostics tab — shows the last 200 log entries with
                    filterable view (All / Warnings+ / Errors+) and a Mark as read button.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Night Light detection status shown in real time on the Diagnostics tab.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Installation Guide added to the ⋮ menu for quick access to hardware setup documentation.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.2.1</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Bug Fix</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Fixed logging — log files were not being created in the published build because .NET 8
                    ignores the NLog section in App.config. Logging is now configured in code and confirmed
                    working. Log files are written to the logs\ folder next to adrilight.exe.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.2.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Sleep / Wake Awareness</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● LEDs automatically pause when the PC sleeps or hibernates and restore when it wakes.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Can be toggled independently in settings (Sleep/Wake Awareness).
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.1.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Black Bar Detection</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Automatically detects letterbox and pillarbox black bars each frame using a fast edge scan.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● LEDs over black bar regions are remapped to sample the nearest picture content edge — all LEDs
                    remain active and reflect real colours at all times.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Toggle and luminance threshold configurable in settings.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Reliability</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Serial baud rate refactored from a hardcoded constant to an internal setting (default 1,000,000); the Arduino sketch must still be flashed to match.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Settings migration logic centralised — version upgrades apply cleanly without touching startup code.
                </TextBlock>

                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 8 0 16">What's new in 3.0.0</TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Platform</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Migrated from .NET Framework 4.7.2 to .NET 8 — lower CPU and GPU usage, faster startup.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● All dependencies updated to current versions, including MaterialDesignThemes 4.9.0.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">New Features</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● TCP control server on port 5080 — any local application or script can send ON, OFF, TOGGLE, STATUS
                    or EXIT commands to control the LEDs without opening the UI.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● LEDs automatically turn off when the Windows session is locked and restore when unlocked.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● LEDs automatically turn off when the screen saver activates and restore when it stops.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Performance</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Dirty flag optimisation — serial data is only sent to the Arduino when screen colours have actually
                    changed, eliminating redundant writes during static content.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Parallel spot processing for large LED counts (40+) using all available CPU cores.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Default frame rate reduced to 30 fps — significantly lower GPU usage with no visible difference on LEDs.
                </TextBlock>

                <TextBlock FontWeight="SemiBold" Margin="0 0 0 6">Reliability</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 4">
                    ● Removed Squirrel auto-updater — eliminates antivirus false positives on startup.
                </TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 12">
                    ● Settings window always shown on first run or after a version change, even when Start Minimised is enabled.
                </TextBlock>
            </StackPanel>
        </materialDesign:Card>

        <!-- TCP API quick reference -->
        <materialDesign:Card Margin="4 0 4 4" Grid.Row="2">
            <StackPanel Margin="38 28 38 28">
                <TextBlock FontWeight="Bold" FontSize="14" Margin="0 0 0 12">TCP Control API  —  127.0.0.1 : 5080</TextBlock>
                <TextBlock TextWrapping="Wrap" Margin="0 0 0 10">
                    Send a plain-text command over TCP; receive a JSON response. Commands are case-insensitive.
                </TextBlock>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">ON</TextBlock>
                    <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Turn LEDs on  →  {"status":"on"}</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">OFF</TextBlock>
                    <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Turn LEDs off  →  {"status":"off"}</TextBlock>
                    <TextBlock Grid.Row="2" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">TOGGLE</TextBlock>
                    <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Toggle on/off  →  {"status":"on"} or {"status":"off"}</TextBlock>
                    <TextBlock Grid.Row="3" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">STATUS</TextBlock>
                    <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Query state and mode  →  {"status":"on","mode":"screen"}</TextBlock>
                    <TextBlock Grid.Row="4" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">MODE SCREEN</TextBlock>
                    <TextBlock Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Switch to screen capture mode  →  {"status":"ok","mode":"screen"}</TextBlock>
                    <TextBlock Grid.Row="5" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">MODE SOUND</TextBlock>
                    <TextBlock Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Switch to sound reactive mode  →  {"status":"ok","mode":"sound"}</TextBlock>
                    <TextBlock Grid.Row="6" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">MODE GAMER</TextBlock>
                    <TextBlock Grid.Row="6" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Switch to gamer mode  →  {"status":"ok","mode":"gamer"}</TextBlock>
                    <TextBlock Grid.Row="7" Grid.Column="0" FontFamily="Consolas" Margin="0 2 16 2">MODE STATUS</TextBlock>
                    <TextBlock Grid.Row="7" Grid.Column="1" TextWrapping="Wrap" Margin="0 2 0 2">Query active mode  →  {"mode":"screen"}</TextBlock>
